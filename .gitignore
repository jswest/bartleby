# benchmarks/ scripts + README are tracked (a reproducible model-selection
# tool). Only the local run outputs and secrets are ignored.
benchmarks/results*
benchmarks/judged*
benchmarks/blind*
benchmarks/*-judged.csv
benchmarks/.env
# Local-only summarizer variants kept out of VC (cloud-cost is out of scope
# for the local-selection benchmark; see benchmarks/README.md).
benchmarks/summarize_openai.py
benchmarks/summarize_omlx_vs_ollama.py
build
*.cast
dist
.DS_Store
*.egg-info
.env
.idea
__pycache__
*.py[oc]
*.swo
*.swp
Thumbs.db
.venv
.vscode
wheels/

# Playwright / `with-playwright` verification artifacts (see CONTRIBUTING.md): the
# MCP writes console logs under .playwright-mcp/ and route screenshots land in the
# repo root. Anchored /*.png so tracked images under docs/ etc. are unaffected.
.playwright-mcp/
/*.png

# .claude/ holds both shared tooling (tracked below) and personal/transient
# state (ignored). Ignore everything, then re-include the shared artifacts.
.claude/*
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
!.claude/skills/
.claude/scratch/
