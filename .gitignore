# benchmarks/ configuration (corpus.yaml, models.yaml, judges.yaml), the
# corpus PDFs, README, and committed fixture sources are tracked (a reproducible
# model-selection tool). The append-only stores, auto-extracted caches, and
# secrets are local-only.
benchmarks/results/
benchmarks/judgements/
# sources/: auto-extracted pdfplumber caches (<doc-id>.txt) are local-only.
# Committed fixture sources for named extraction variants are tracked — add them
# to the negation list here when a new fixture is committed.
benchmarks/sources/*.txt
!benchmarks/sources/psc-order-0109-docling.txt
!benchmarks/sources/neada-heating-0461-image-fixture.txt
benchmarks/blind*
benchmarks/*.jsonl
benchmarks/*.csv
benchmarks/.env
# Pre-#268 local-only artifacts that may linger in working copies.
benchmarks/results*
benchmarks/judged*
benchmarks/summarize_openai.py
benchmarks/summarize_omlx_vs_ollama.py
build
*.cast
dist
.DS_Store
*.egg-info
.env
.idea
__pycache__
*.py[oc]
*.swo
*.swp
Thumbs.db
.venv
.vscode
wheels/

# Playwright / `with-playwright` verification artifacts (see CONTRIBUTING.md): the
# MCP writes console logs under .playwright-mcp/ and route screenshots land in the
# repo root. Anchored /*.png so tracked images under docs/ etc. are unaffected.
.playwright-mcp/
/*.png

# .claude/ holds both shared tooling (tracked below) and personal/transient
# state (ignored). Ignore everything, then re-include the shared artifacts.
.claude/*
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
!.claude/skills/
!.claude/ship.toml
.claude/scratch/
# Machine-local press provenance — names an absolute drawer path; noise to clones.
.claude/skills/*/.stamp
